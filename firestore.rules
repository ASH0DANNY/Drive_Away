rules_version = '2';

// Deploy: paste into Firebase Console → Firestore Database → Rules, or
// `firebase deploy --only firestore:rules` if you're using the CLI.
//
// Model:
// - siteConfig, vehicles: public read (needed for the site to render),
//   write restricted to admins (checked via users/{uid}.role).
// - users: everyone can read their own doc (and public fields needed for
//   admin lists); only admins can write role. Users can update their own
//   non-role fields.
// - bookings: a user can create/read/update only their own bookings.
//   Admins can read/update all (for the Bookings Manager).
// - payments: created by the client during the dummy payment flow, tied
//   to a booking the user owns; admins can read all.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /siteConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      // owners can update their own doc, but never their own role
      allow update: if (isOwner(userId) &&
                          request.resource.data.role == resource.data.role) ||
                        isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() ||
                     (isSignedIn() && resource.data.userId == request.auth.uid);
      // regular customers can only create a booking for themselves; admins
      // can also create one on behalf of a walk-in (see WALKIN_USER_ID)
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) ||
                       isAdmin();
      allow update: if isAdmin() ||
                       (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /payments/{paymentId} {
      allow read: if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    match /coupons/{couponId} {
      // anyone signed in can look up a coupon by code to validate it at
      // checkout, and bump its usedCount when redeeming; only admins manage them
      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin() ||
                       (isSignedIn() &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["usedCount"]));
    }
  }
}
